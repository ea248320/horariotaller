# Conexión a Postgres.
# Local (embedded, npm run db:local): postgres://preuflow:preuflow@localhost:5433/preuflow
# Supabase + Railway: usar SIEMPRE el connection string del Session pooler (IPv4),
#   formato: postgres://postgres.TU-PROJECT-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
#   (la "Direct connection" solo resuelve a IPv6 y falla en Railway con "Network is unreachable")
DATABASE_URL=postgres://preuflow:preuflow@localhost:5433/preuflow

# Secreto para firmar los tokens de sesión (JWT). Cambiar en producción.
JWT_SECRET=cambia-esto-en-produccion

PORT=4000

# Correo (Resend). Sin esta clave, los avisos por correo quedan inactivos
# y solo se generan notificaciones internas (comportamiento esperado).
# RESEND_API_KEY=
# EMAIL_FROM=PreuFlow <avisos@tudominio.cl>

# Cobro de la suscripción SaaS vía Flow (CLP). Sin credenciales, el checkout
# muestra un aviso en vez de fallar. NO activar credenciales reales sin confirmar.
# FLOW_API_KEY=
# FLOW_SECRET_KEY=
# FLOW_BASE_URL=https://sandbox.flow.cl/api
# APP_BASE_URL=http://localhost:5173
